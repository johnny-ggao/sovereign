# Application
APP_ENV=production

# Docker
DATA_DIR=/data/sovereign
NGINX_PORT=80
PG_PORT=5433
REDIS_PORT=6380

# Database
DB_USER=sovereign
DB_PASSWORD=sovereign_dev
DB_NAME=sovereign
SOVEREIGN_DATABASE_HOST=postgres
SOVEREIGN_DATABASE_PORT=5432
SOVEREIGN_DATABASE_USER=sovereign
SOVEREIGN_DATABASE_PASSWORD=sovereign_dev
SOVEREIGN_DATABASE_NAME=sovereign

# Redis
REDIS_PASSWORD=redis_dev
SOVEREIGN_REDIS_ADDR=redis:6379
SOVEREIGN_REDIS_PASSWORD=redis_dev

# JWT (generate with: openssl rand -hex 32)
SOVEREIGN_JWT_ACCESS__SECRET=your_access_secret_here
SOVEREIGN_JWT_REFRESH__SECRET=your_refresh_secret_here

# AES-256 Key (generate with: openssl rand -hex 32)
SOVEREIGN_CRYPTO_AES__KEY=your_aes_256_key_here

# Cobo Wallet (generate keys with: cd server && go run scripts/generate_cobo_keys.go)
SOVEREIGN_COBO_USE__MOCK=false
SOVEREIGN_COBO_BASE__URL=https://api.cobo.com
SOVEREIGN_COBO_API__SECRET=your_ed25519_private_key_hex
SOVEREIGN_COBO_API__PUB__KEY=your_ed25519_public_key_hex
SOVEREIGN_COBO_WALLET__ID=your_cobo_wallet_id
SOVEREIGN_COBO_WEBHOOK__PUB__KEY=your_cobo_webhook_public_key

# Google OAuth
SOVEREIGN_GOOGLE_CLIENT__ID=your_google_client_id
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id

# Frontend (for Docker build)
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_WS_URL=

# KYC (Sumsub)
SOVEREIGN_KYC_API__KEY=your_kyc_api_key
SOVEREIGN_KYC_API__SECRET=your_kyc_api_secret
