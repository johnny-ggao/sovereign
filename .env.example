# Application
APP_ENV=production

# Docker
DATA_DIR=/data/sovereign
NGINX_PORT=80
PG_PORT=5433
REDIS_PORT=6380

# Database (双下划线 __ 分隔层级，单下划线保持原样)
DB_USER=sovereign
DB_PASSWORD=sovereign_dev
DB_NAME=sovereign
SOVEREIGN_DATABASE__HOST=postgres
SOVEREIGN_DATABASE__PORT=5432
SOVEREIGN_DATABASE__USER=sovereign
SOVEREIGN_DATABASE__PASSWORD=sovereign_dev
SOVEREIGN_DATABASE__NAME=sovereign

# Redis
REDIS_PASSWORD=redis_dev
SOVEREIGN_REDIS__ADDR=redis:6379
SOVEREIGN_REDIS__PASSWORD=redis_dev

# JWT (generate with: openssl rand -hex 32)
SOVEREIGN_JWT__ACCESS_SECRET=your_access_secret_here
SOVEREIGN_JWT__REFRESH_SECRET=your_refresh_secret_here

# AES-256 Key (generate with: openssl rand -hex 32)
SOVEREIGN_CRYPTO__AES_KEY=your_aes_256_key_here

# Cobo Wallet
SOVEREIGN_COBO__USE_MOCK=false
SOVEREIGN_COBO__BASE_URL=https://api.cobo.com
SOVEREIGN_COBO__API_SECRET=your_ed25519_private_key_hex
SOVEREIGN_COBO__API_PUB_KEY=your_ed25519_public_key_hex
SOVEREIGN_COBO__WALLET_ID=your_cobo_wallet_id
SOVEREIGN_COBO__WEBHOOK_PUB_KEY=
SOVEREIGN_COBO__WITHDRAW_ADDRESSES__BEP20=your_bsc_withdraw_address
SOVEREIGN_COBO__WITHDRAW_ADDRESSES__TRC20=your_tron_withdraw_address

# Google OAuth
SOVEREIGN_GOOGLE__CLIENT_ID=your_google_client_id
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id

# Frontend (for Docker build)
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_WS_URL=
